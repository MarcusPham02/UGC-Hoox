# Generate a keystore:
#   keytool -genkey -v -keystore ~/hooks-release.jks -keyalg RSA -keysize 2048 -validity 10000 -alias hooks
#
# Then copy this file to key.properties and fill in the values:
storePassword=YOUR_STORE_PASSWORD
keyPassword=YOUR_KEY_PASSWORD
keyAlias=hooks
storeFile=/Users/YOUR_USERNAME/hooks-release.jks
